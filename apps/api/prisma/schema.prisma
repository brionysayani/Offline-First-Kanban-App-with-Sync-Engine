generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boards    Board[]
}

model Board {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  version     Int      @default(1)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns     BoardColumn[]
  cards       Card[]
  operationLogs OperationLog[]

  @@index([userId])
}

model BoardColumn {
  id          String   @id @default(cuid())
  title       String
  position    Int      @default(0)
  version     Int      @default(1)
  boardId     String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards       Card[]

  @@index([boardId])
}

model Card {
  id          String   @id @default(cuid())
  title       String
  description String?
  position    Int      @default(0)
  version     Int      @default(1)
  boardId     String
  columnId    String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board       Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column      BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([columnId])
}

model OperationLog {
  id               String   @id @default(cuid())
  operationId      String   @unique
  type             String
  entityType       String
  entityId         String
  boardId          String?
  payload          Json
  baseVersion      Int
  resultingVersion Int
  createdAt        DateTime @default(now())

  board            Board?   @relation(fields: [boardId], references: [id], onDelete: SetNull)

  @@index([boardId])
  @@index([entityType, entityId])
}
