{
  "name": "offline-first-kanban-api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "prisma migrate deploy && node dist/apps/api/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.6.3",
    "bcryptjs": "^2.4.3",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.1",
    "prisma": "^5.6.3",
    "socket.io": "^4.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/node": "^22.10.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
